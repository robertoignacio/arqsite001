---
// scoped style
import '../styles/tags.css';

// layout wrapper
import BaseLayout from "./BaseLayout.astro";

// prop forwarder
const { frontmatter } = Astro.props;

/* 
available frontmatter fields:
title: 'string'
pubDate: date
description: 'string'
author: 'string'
image:
    url: ''
    alt: ''
tags: ['string', ...]

*/
---

<BaseLayout pageTitle={frontmatter.title}>
    <h1 class="art-title">{frontmatter.title}</h1>
    <p class="date">{frontmatter.pubDate.toLocaleDateString()}</p>
    <p class="author">Escrito por: {frontmatter.author}</p>
    <img src={frontmatter.image.url} width="300" alt={frontmatter.image.alt} />

    <div class="tags">
        {frontmatter.tags.map((tag: string) => (<p class="tag"><a href={`/tags/${tag}`}>{tag}</a></p>))}
    </div>

    <slot />
</BaseLayout>