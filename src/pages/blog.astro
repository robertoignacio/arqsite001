---
// collection
import { getCollection } from "astro:content";

// base page layout wrapper
import BaseLayout from '../layouts/BaseLayout.astro';

// components
import ArticleBlock from '../components/ArticleBlock.astro';
import BlogPost from '../components/BlogPost.astro';

// return an array of objects for each blog post
// returned by import.meta.glob()
// use case: query data from local files
// const allPosts = Object.values(import.meta.glob('./blog-posts/*.md', { eager: true }));
const allPosts = await getCollection("blog");

// passed props to BaseLayout
const pageTitle = 'Artículos';
---

<BaseLayout pageTitle={pageTitle}>

        <h1>{pageTitle}</h1>
        <p>Blog</p>

        <ul>
            {
                allPosts.map((post: any) => (
                    <ArticleBlock url={`/blog-posts/${post.id}/`} title={post.data.title} />
                ))
            }
        </ul>
</BaseLayout>